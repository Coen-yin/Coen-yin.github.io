<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minecraft Server - Join Now!</title>
    <link rel="icon" type="image/png" href="icon.png">
    <link rel="stylesheet" href="styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Minecraft:wght@400;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <i class="fas fa-cube"></i>
                <span>Minecraft Server</span>
            </div>
            <ul class="nav-menu">
                <li class="nav-item"><a href="#home" class="nav-link">Home</a></li>
                <li class="nav-item"><a href="#features" class="nav-link">Features</a></li>
                <li class="nav-item"><a href="#rules" class="nav-link">Rules</a></li>
                <li class="nav-item"><a href="#staff" class="nav-link">Staff</a></li>
                <li class="nav-item"><a href="#vote" class="nav-link">Vote</a></li>
            </ul>
            <button class="nav-toggle" id="navToggle">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content">
            <h1 class="hero-title">Welcome to Our Minecraft Server</h1>
            <p class="hero-subtitle">Join thousands of players in an epic adventure!</p>
            <div class="server-info-box">
                <div class="server-ip">
                    <span class="label">Server IP:</span>
                    <span class="ip">play.minecraftserver.com</span>
                    <button class="copy-btn" onclick="copyIP()">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <div class="server-stats">
                    <div class="stat">
                        <i class="fas fa-users"></i>
                        <span id="onlinePlayers">Loading...</span>
                        <small>Players Online</small>
                    </div>
                    <div class="stat">
                        <i class="fas fa-server"></i>
                        <span id="serverStatus">Checking...</span>
                        <small>Status</small>
                    </div>
                    <div class="stat">
                        <i class="fas fa="fas fa-globe"></i>
                        <span>Survival | Creative | Minigames</span>
                        <small>Game Modes</small>
                    </div>
                </div>
            </div>
            <div class="hero-buttons">
                <a href="#features" class="btn btn-primary">
                    <i class="fas fa-play"></i>
                    Get Started
                </a>
                <a href="https://discord.gg/yourserver" target="_blank" class="btn btn-secondary">
                    <i class="fab fa-discord"></i>
                    Join Discord
                </a>
            </div>
        </div>
        <div class="hero-background">
            <div class="minecraft-blocks"></div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features">
        <div class="container">
            <h2 class="section-title">Server Features</h2>
            <p class="section-subtitle">Discover what makes our server special</p>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-mountain"></i>
                    </div>
                    <h3>Survival Mode</h3>
                    <p>Experience classic Minecraft survival with custom enhancements, economy system, and player shops.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-paintbrush"></i>
                    </div>
                    <h3>Creative Mode</h3>
                    <p>Unleash your creativity with unlimited resources, WorldEdit, and plot protection for your builds.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-gamepad"></i>
                    </div>
                    <h3>Minigames</h3>
                    <p>Enjoy various minigames including SkyWars, BedWars, Parkour, and more with rewards!</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>Grief Protection</h3>
                    <p>Claim your land and protect your builds with our advanced protection system.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-coins"></i>
                    </div>
                    <h3>Economy System</h3>
                    <p>Earn money, trade with players, and build your empire in our server economy.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h3>Ranks & Rewards</h3>
                    <p>Level up through ranks, unlock perks, and earn exclusive rewards as you play.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-comments"></i>
                    </div>
                    <h3>Active Community</h3>
                    <p>Join our friendly community on Discord and in-game chat with helpful players and staff.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3>24/7 Uptime</h3>
                    <p>Powerful dedicated servers ensuring lag-free gameplay with 99.9% uptime guarantee.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Rules Section -->
    <section id="rules" class="rules">
        <div class="container">
            <h2 class="section-title">Server Rules</h2>
            <p class="section-subtitle">Please follow these rules to ensure everyone has fun</p>
            <div class="rules-grid">
                <div class="rule-card">
                    <div class="rule-number">1</div>
                    <h3>No Griefing</h3>
                    <p>Respect other players' builds and property. Griefing will result in a ban.</p>
                </div>
                <div class="rule-card">
                    <div class="rule-number">2</div>
                    <h3>Be Respectful</h3>
                    <p>Treat all players and staff with respect. No harassment, bullying, or hate speech.</p>
                </div>
                <div class="rule-card">
                    <div class="rule-number">3</div>
                    <h3>No Cheating</h3>
                    <p>Hacking, x-ray, or any unfair advantage is strictly prohibited.</p>
                </div>
                <div class="rule-card">
                    <div class="rule-number">4</div>
                    <h3>No Spam</h3>
                    <p>Avoid spamming chat, commands, or advertising other servers.</p>
                </div>
                <div class="rule-card">
                    <div class="rule-number">5</div>
                    <h3>English Only</h3>
                    <p>Please use English in public chat to ensure everyone can communicate.</p>
                </div>
                <div class="rule-card">
                    <div class="rule-number">6</div>
                    <h3>Listen to Staff</h3>
                    <p>Follow instructions from moderators and admins at all times.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Staff Section -->
    <section id="staff" class="staff">
        <div class="container">
            <h2 class="section-title">Meet Our Staff</h2>
            <p class="section-subtitle">Our dedicated team is here to help</p>
            <div class="staff-grid">
                <div class="staff-card">
                    <div class="staff-avatar">
                        <img src="https://minotar.net/helm/Steve/100.png" alt="Staff">
                    </div>
                    <h3>ServerOwner</h3>
                    <span class="staff-role owner">Owner</span>
                    <p>Founder and server administrator</p>
                </div>
                <div class="staff-card">
                    <div class="staff-avatar">
                        <img src="https://minotar.net/helm/Alex/100.png" alt="Staff">
                    </div>
                    <h3>AdminPlayer</h3>
                    <span class="staff-role admin">Admin</span>
                    <p>Server management and support</p>
                </div>
                <div class="staff-card">
                    <div class="staff-avatar">
                        <img src="https://minotar.net/helm/Herobrine/100.png" alt="Staff">
                    </div>
                    <h3>ModPlayer</h3>
                    <span class="staff-role mod">Moderator</span>
                    <p>Community moderation and assistance</p>
                </div>
                <div class="staff-card">
                    <div class="staff-avatar">
                        <img src="https://minotar.net/helm/Notch/100.png" alt="Staff">
                    </div>
                    <h3>HelperPlayer</h3>
                    <span class="staff-role helper">Helper</span>
                    <p>Assisting new players</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Vote Section -->
    <section id="vote" class="vote">
        <div class="container">
            <h2 class="section-title">Vote for Our Server</h2>
            <p class="section-subtitle">Help us grow and earn rewards!</p>
            <div class="vote-grid">
                <div class="vote-card">
                    <h3>PlanetMinecraft</h3>
                    <p>Vote and earn 1 Diamond</p>
                    <a href="#" class="btn btn-vote">Vote Now</a>
                </div>
                <div class="vote-card">
                    <h3>Minecraft-Server-List</h3>
                    <p>Vote and earn 1 Diamond</p>
                    <a href="#" class="btn btn-vote">Vote Now</a>
                </div>
                <div class="vote-card">
                    <h3>TopG</h3>
                    <p>Vote and earn 1 Diamond</p>
                    <a href="#" class="btn btn-vote">Vote Now</a>
                </div>
            </div>
            <div class="vote-rewards">
                <h3>Vote Rewards</h3>
                <ul>
                    <li><i class="fas fa-check"></i> 1 Diamond per vote</li>
                    <li><i class="fas fa-check"></i> Bonus rewards for voting streak</li>
                    <li><i class="fas fa-check"></i> Monthly top voter gets exclusive rank</li>
                    <li><i class="fas fa-check"></i> Vote keys for crate rewards</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Minecraft Server</h3>
                    <p>Join the adventure today and become part of our amazing community!</p>
                    <div class="social-links">
                        <a href="#" class="social-link"><i class="fab fa-discord"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <div class="footer-section">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="#home">Home</a></li>
                        <li><a href="#features">Features</a></li>
                        <li><a href="#rules">Rules</a></li>
                        <li><a href="#staff">Staff</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Server Info</h3>
                    <ul>
                        <li>IP: play.minecraftserver.com</li>
                        <li>Version: 1.20.x</li>
                        <li>Location: United States</li>
                        <li>Type: Survival, Creative, Minigames</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 Minecraft Server. All rights reserved. Not affiliated with Mojang AB.</p>
            </div>
        </div>
    </footer>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script src="script.js"></script>
        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-container">
                    <div class="logo-wrapper">
                        <img src="talkiegen.png" alt="Talkie Gen AI" class="logo">
                        <div class="logo-pulse"></div>
                    </div>
                    <div class="brand-info">
                        <span class="brand-name">Talkie Gen</span>
                        <span class="brand-subtitle">AI Assistant</span>
                    </div>
                </div>
                <button class="new-chat-btn" id="newChatBtn">
                    <i class="fas fa-plus"></i>
                    <span>New Chat</span>
                    <div class="btn-shine"></div>
                </button>
            </div>
            
            <div class="chat-history" id="chatHistory">
                <!-- Chat history will be populated here -->
            </div>
            
            <div class="sidebar-footer">
                <div class="user-menu" id="userMenu">
                    <div class="user-avatar">
                        <span id="userAvatar">G</span>
                        <div class="avatar-status"></div>
                    </div>
                    <div class="user-info">
                        <span class="username" id="displayUsername">Guest</span>
                        <span class="user-status" id="userStatus">Not signed in</span>
                    </div>
                    <i class="fas fa-chevron-up"></i>
                </div>
                <div class="user-dropdown" id="userDropdown">
                    <!-- Auth buttons (shown when not logged in) -->
                    <button class="dropdown-item" id="loginBtn">
                        <i class="fas fa-sign-in-alt"></i>
                        <span>Sign In</span>
                    </button>
                    <button class="dropdown-item" id="signupBtn">
                        <i class="fas fa-user-plus"></i>
                        <span>Sign Up</span>
                    </button>
                    
                    <!-- User menu items (shown when logged in) -->
                    <button class="dropdown-item" id="profileBtn" style="display: none;">
                        <i class="fas fa-user"></i>
                        <span>Profile</span>
                    </button>
                    <button class="dropdown-item" id="adminBtn" style="display: none;">
                        <i class="fas fa-shield-alt"></i>
                        <span>Admin Panel</span>
                    </button>
                    <button class="dropdown-item" id="themeToggle">
                        <i class="fas fa-moon"></i>
                        <span>Dark mode</span>
                    </button>
                    <button class="dropdown-item" id="exportAllBtn">
                        <i class="fas fa-download"></i>
                        <span>Export chats</span>
                    </button>
                    <button class="dropdown-item" id="clearAllBtn">
                        <i class="fas fa-trash"></i>
                        <span>Clear all</span>
                    </button>
                    
                    <!-- Logout button (shown when logged in) -->
                    <button class="dropdown-item" id="logoutBtn" style="display: none;">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Sign Out</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Header -->
            <div class="header">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="header-title">
                    <span>Talkie Gen AI</span>
                    <div class="ai-status">
                        <div class="status-dot"></div>
                        <span>Ready to help</span>
                    </div>
                </div>
                <div class="header-actions">
                    <button class="header-btn" id="docsBtn" title="Documentation">
                        <i class="fas fa-book"></i>
                    </button>
                    <button class="header-btn" id="shareBtn">
                        <i class="fas fa-share"></i>
                    </button>
                    <button class="header-btn" id="settingsBtn">
                        <i class="fas fa-cog"></i>
                    </button>
                </div>
            </div>

            <!-- Chat Container -->
            <div class="chat-container" id="chatContainer">
                <!-- Welcome Screen -->
                <div class="welcome-screen" id="welcomeScreen">
                    <div class="welcome-content">
                        <div class="welcome-animation">
                            <div class="welcome-logo">
                                <img src="talkiegen.png" alt="Talkie Gen AI">
                                <div class="logo-glow"></div>
                            </div>
                            <div class="floating-elements">
                                <div class="float-element"></div>
                                <div class="float-element"></div>
                                <div class="float-element"></div>
                            </div>
                        </div>
                        <h1>Welcome to <span class="gradient-text">Talkie Gen AI</span></h1>
                        <p class="welcome-subtitle">Your intelligent AI companion, ready to assist with anything you need. Let's start a conversation!</p>
                        
                        <div class="example-prompts">
                            <div class="prompt-card" onclick="sendPrompt('Explain quantum computing in simple terms')">
                                <div class="card-icon">
                                    <i class="fas fa-atom"></i>
                                </div>
                                <div class="card-content">
                                    <h3>Science & Tech</h3>
                                    <p>Explain quantum computing</p>
                                </div>
                                <div class="card-arrow">
                                    <i class="fas fa-arrow-right"></i>
                                </div>
                            </div>
                            
                            <div class="prompt-card" onclick="sendPrompt('Write a Python function to find prime numbers')">
                                <div class="card-icon">
                                    <i class="fas fa-code"></i>
                                </div>
                                <div class="card-content">
                                    <h3>Programming</h3>
                                    <p>Help with coding</p>
                                </div>
                                <div class="card-arrow">
                                    <i class="fas fa-arrow-right"></i>
                                </div>
                            </div>
                            
                            <div class="prompt-card" onclick="sendPrompt('Create a 7-day itinerary for visiting Tokyo')">
                                <div class="card-icon">
                                    <i class="fas fa-plane"></i>
                                </div>
                                <div class="card-content">
                                    <h3>Travel Planning</h3>
                                    <p>Plan a trip to Tokyo</p>
                                </div>
                                <div class="card-arrow">
                                    <i class="fas fa-arrow-right"></i>
                                </div>
                            </div>
                            
                            <div class="prompt-card" onclick="sendPrompt('Write a creative short story about time travel')">
                                <div class="card-icon">
                                    <i class="fas fa-pen-fancy"></i>
                                </div>
                                <div class="card-content">
                                    <h3>Creative Writing</h3>
                                    <p>Write a story</p>
                                </div>
                                <div class="card-arrow">
                                    <i class="fas fa-arrow-right"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Messages Area -->
                <div class="messages-area" id="messagesArea">
                    <!-- Messages will be added here -->
                </div>

                <!-- Typing Indicator -->
                <div class="typing-indicator" id="typingIndicator">
                    <div class="typing-avatar">
                        <img src="talkiegen.png" alt="Talkie Gen AI">
                        <div class="avatar-pulse"></div>
                    </div>
                    <div class="typing-bubble">
                        <div class="typing-text">Talkie Gen is thinking</div>
                        <div class="typing-dots">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Input Area -->
            <div class="input-area">
                <div class="input-container">
                    <div class="input-wrapper">
                        <textarea 
                            id="messageInput" 
                            placeholder="Message Talkie Gen AI..." 
                            rows="1"
                            maxlength="4000"
                        ></textarea>
                        <div class="input-actions">
                            <button class="input-btn" id="attachBtn" title="Attach file">
                                <i class="fas fa-paperclip"></i>
                            </button>
                            <button class="input-btn" id="voiceBtn" title="Voice input">
                                <i class="fas fa-microphone"></i>
                            </button>
                            <button class="send-button" id="sendButton" disabled>
                                <i class="fas fa-paper-plane"></i>
                                <div class="send-ripple"></div>
                            </button>
                        </div>
                    </div>
                    <div class="input-footer">
                        <span class="disclaimer">Talkie Gen AI can make mistakes. Consider checking important information.</span>
                        <div class="word-count" id="wordCount">0/4000</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile Overlay -->
    <div class="mobile-overlay" id="mobileOverlay"></div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Admin Panel Modal -->
    <div class="modal-overlay" id="adminModalOverlay">
        <div class="auth-modal" id="adminModal" style="max-width: 800px;">
            <div class="modal-header">
                <h2>Admin Dashboard</h2>
                <p>Website statistics and management</p>
                <button class="modal-close" id="closeAdminModal">&times;</button>
            </div>
            <div class="admin-content">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number" id="totalVisitors">0</div>
                            <div class="stat-label">Total Visits</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-user-friends"></i>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number" id="uniqueVisitors">0</div>
                            <div class="stat-label">Unique Visitors</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-calendar-day"></i>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number" id="todayVisits">0</div>
                            <div class="stat-label">Today's Visits</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-registered"></i>
                        </div>
                        <div class="stat-info">
                            <div class="stat-number" id="registeredUsers">0</div>
                            <div class="stat-label">Registered Users</div>
                        </div>
                    </div>
                </div>
                
                <div class="admin-section">
                    <h3>User Management</h3>
                    <div class="user-management-panel">
                        <div class="user-search">
                            <input type="email" id="userSearchInput" placeholder="Enter user email to manage..." />
                            <button id="searchUserBtn" class="search-btn">
                                <i class="fas fa-search"></i>
                                Search
                            </button>
                        </div>
                        <div class="user-details" id="userDetails" style="display: none;">
                            <div class="user-card">
                                <div class="user-info">
                                    <h4 id="selectedUserName">User Name</h4>
                                    <p id="selectedUserEmail">user@example.com</p>
                                    <div class="user-badges">
                                        <span id="selectedUserRole" class="role-badge">Regular</span>
                                        <span id="selectedUserPro" class="pro-badge" style="display: none;">Pro</span>
                                    </div>
                                </div>
                                <div class="user-actions">
                                    <button id="toggleProBtn" class="admin-action-btn">
                                        <i class="fas fa-crown"></i>
                                        Toggle Pro
                                    </button>
                                    <button id="toggleAdminBtn" class="admin-action-btn">
                                        <i class="fas fa-shield-alt"></i>
                                        Toggle Admin
                                    </button>
                                    <button id="deleteUserBtn" class="admin-action-btn danger">
                                        <i class="fas fa-trash"></i>
                                        Delete User
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="admin-section">
                    <h3>Recent Activity</h3>
                    <div class="activity-list" id="activityList">
                        <!-- Recent activity will be populated here -->
                    </div>
                </div>
                
                <div class="admin-section">
                    <h3>System Information</h3>
                    <div class="system-info">
                        <div class="info-item">
                            <span class="info-label">AI Model:</span>
                            <span class="info-value" id="currentAiModel">Talkiegenpro (Puter)</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Data Storage:</span>
                            <span class="info-value">Browser LocalStorage</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Theme System:</span>
                            <span class="info-value">Light / Dark / Pro / Owner</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Profile Modal -->
    <div class="modal-overlay" id="profileModalOverlay">
        <div class="auth-modal" id="profileModal">
            <div class="modal-header">
                <h2>Edit Profile</h2>
                <p>Customize your profile settings</p>
                <button class="modal-close" id="closeProfileModal">&times;</button>
            </div>
            <form class="auth-form" id="profileForm">
                <div class="form-group">
                    <label for="profileName">Display Name</label>
                    <input type="text" id="profileName" required>
                </div>
                
                <div class="form-group">
                    <label for="profileBio">Bio</label>
                    <textarea id="profileBio" placeholder="Tell us a bit about yourself..." maxlength="200"></textarea>
                    <small>A short description about yourself (max 200 characters)</small>
                </div>
                
                <div class="form-group">
                    <label for="profileLocation">Location</label>
                    <input type="text" id="profileLocation" placeholder="e.g., San Francisco, CA">
                </div>
                
                <div class="form-group">
                    <label for="profileTimezone">Timezone</label>
                    <select id="profileTimezone">
                        <option value="">Select timezone...</option>
                        <option value="America/Los_Angeles">Pacific Time (PT)</option>
                        <option value="America/Denver">Mountain Time (MT)</option>
                        <option value="America/Chicago">Central Time (CT)</option>
                        <option value="America/New_York">Eastern Time (ET)</option>
                        <option value="Europe/London">London (GMT)</option>
                        <option value="Europe/Paris">Paris (CET)</option>
                        <option value="Asia/Tokyo">Tokyo (JST)</option>
                        <option value="Asia/Shanghai">Shanghai (CST)</option>
                        <option value="Australia/Sydney">Sydney (AEDT)</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="profilePhoto">Profile Photo</label>
                    <div class="photo-upload-container">
                        <div class="current-photo" id="currentPhoto">
                            <span id="photoPreview">A</span>
                        </div>
                        <input type="file" id="profilePhotoInput" accept="image/*" style="display: none;">
                        <button type="button" class="upload-btn" id="uploadPhotoBtn">
                            <i class="fas fa-camera"></i>
                            Change Photo
                        </button>
                        <button type="button" class="remove-btn" id="removePhotoBtn" style="display: none;">
                            Remove Photo
                        </button>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="preferredLanguage">Preferred Language</label>
                    <select id="preferredLanguage">
                        <option value="en">English</option>
                        <option value="es">Spanish</option>
                        <option value="fr">French</option>
                        <option value="de">German</option>
                        <option value="ja">Japanese</option>
                        <option value="zh">Chinese</option>
                        <option value="ko">Korean</option>
                        <option value="pt">Portuguese</option>
                        <option value="it">Italian</option>
                        <option value="ru">Russian</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <h4>Privacy Settings</h4>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" id="shareUsageStats">
                            <span class="toggle-slider"></span>
                            Share usage statistics
                        </label>
                        <small>Help improve the service by sharing anonymous usage data</small>
                    </div>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" id="allowDataCollection" checked>
                            <span class="toggle-slider"></span>
                            Allow conversation analysis
                        </label>
                        <small>Allow analysis of conversations to improve AI responses</small>
                    </div>
                </div>
                
                <button type="submit" class="auth-btn">Save Changes</button>
            </form>
        </div>
    </div>

    <!-- Authentication Modals -->
    <div class="modal-overlay" id="authModalOverlay">
        <!-- Login Modal -->
        <div class="auth-modal" id="loginModal">
            <div class="modal-header">
                <h2>Welcome back</h2>
                <p>Sign in to your account</p>
                <button class="modal-close" id="closeLoginModal">&times;</button>
            </div>
            <div class="auth-divider">
                <span>Sign in with email and password</span>
            </div>
            <form class="auth-form" id="loginForm">
                <div class="form-group">
                    <label for="loginEmail">Email</label>
                    <input type="email" id="loginEmail" required>
                </div>
                <div class="form-group">
                    <label for="loginPassword">Password</label>
                    <input type="password" id="loginPassword" required>
                </div>
                <button type="submit" class="auth-btn">Sign In</button>
            </form>
            <div class="auth-footer">
                <p>Don't have an account? <a href="#" id="showSignupModal">Sign up</a></p>
            </div>
        </div>

        <!-- Signup Modal -->
        <div class="auth-modal" id="signupModal">
            <div class="modal-header">
                <h2>Create account</h2>
                <p>Join Talkie Gen AI today</p>
                <button class="modal-close" id="closeSignupModal">&times;</button>
            </div>
            <div class="auth-divider">
                <span>Create account with email and password</span>
            </div>
            <form class="auth-form" id="signupForm">
                <div class="form-group">
                    <label for="signupName">Full Name</label>
                    <input type="text" id="signupName" required>
                </div>
                <div class="form-group">
                    <label for="signupEmail">Email</label>
                    <input type="email" id="signupEmail" required>
                </div>
                <div class="form-group">
                    <label for="signupPassword">Password</label>
                    <input type="password" id="signupPassword" required minlength="6">
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" required>
                </div>
                <button type="submit" class="auth-btn">Create Account</button>
            </form>
            <div class="auth-footer">
                <p>Already have an account? <a href="#" id="showLoginModal">Sign in</a></p>
            </div>
        </div>
    </div>

    <!-- Enhanced Settings Modal -->
    <div class="modal-overlay" id="settingsModalOverlay">
        <div class="auth-modal" id="settingsModal" style="max-width: 600px;">
            <div class="modal-header">
                <h2>Conversation Settings</h2>
                <p>Customize your AI experience</p>
                <button class="modal-close" id="closeSettingsModal">&times;</button>
            </div>
            <div class="settings-content">
                <div class="settings-section">
                    <h3>Context & Memory</h3>
                    <div class="setting-item">
                        <label for="contextLength">Context Length</label>
                        <select id="contextLength">
                            <option value="5">Short (5 messages)</option>
                            <option value="10">Medium (10 messages)</option>
                            <option value="15">Long (15 messages)</option>
                            <option value="20">Extended (20 messages)</option>
                        </select>
                        <small>How many previous messages to remember in conversation</small>
                    </div>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" id="enableMemory">
                            <span class="toggle-slider"></span>
                            Enable Memory Across Sessions
                        </label>
                        <small>Remember your preferences and conversation history</small>
                    </div>
                </div>

                <div class="settings-section">
                    <h3>Response Style</h3>
                    <div class="setting-item">
                        <label for="responseStyle">Response Style</label>
                        <select id="responseStyle">
                            <option value="concise">Concise</option>
                            <option value="balanced">Balanced</option>
                            <option value="detailed">Detailed</option>
                            <option value="creative">Creative</option>
                        </select>
                        <small>How detailed and creative should responses be</small>
                    </div>
                    <div class="setting-item">
                        <label for="personalityMode">AI Personality</label>
                        <select id="personalityMode">
                            <option value="professional">Professional</option>
                            <option value="friendly">Friendly</option>
                            <option value="casual">Casual</option>
                            <option value="academic">Academic</option>
                        </select>
                        <small>The personality style for AI responses</small>
                    </div>
                </div>

                <div class="settings-section">
                    <h3>AI Model Selection</h3>
                    <div class="setting-item">
                        <label for="aiModel">AI Model</label>
                        <select id="aiModel">
                            <option value="Talkiegenpro">Talkiegenpro (Pro Performance)</option>
                            <option value="TalkiegenFast">TalkiegenFast (Faster Responses)</option>
                            <option value="TalkiegenLatest">TalkiegenLatest (Latest Features)</option>
                            <option value="TalkiegenStandard">TalkiegenStandard (Standard Model)</option>
                        </select>
                        <small>Choose the AI model that best fits your needs</small>
                    </div>
                </div>

                <div class="settings-section">
                    <h3>Conversation Features</h3>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" id="enableFollowUps">
                            <span class="toggle-slider"></span>
                            Show Follow-up Questions
                        </label>
                        <small>Display suggested follow-up questions after AI responses</small>
                    </div>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" id="rememberPreferences">
                            <span class="toggle-slider"></span>
                            Remember User Preferences
                        </label>
                        <small>Learn and remember your interests and preferences</small>
                    </div>
                </div>

                <div class="settings-section">
                    <h3>Search & Tools</h3>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" id="enableWebSearch" checked>
                            <span class="toggle-slider"></span>
                            Enable Web Search
                        </label>
                        <small>Allow AI to search the web for up-to-date information</small>
                    </div>
                    <div class="setting-item">
                        <label for="searchBehavior">Search Behavior</label>
                        <select id="searchBehavior">
                            <option value="auto">Automatic (AI decides when to search)</option>
                            <option value="always">Always search for current events</option>
                            <option value="manual">Manual (search only when asked)</option>
                        </select>
                        <small>How the AI should use web search capabilities</small>
                    </div>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" id="showSearchResults" checked>
                            <span class="toggle-slider"></span>
                            Show Search Sources
                        </label>
                        <small>Display which sources were used for web-based answers</small>
                    </div>
                </div>

                <div class="settings-section">
                    <h3>Data Management</h3>
                    <div class="setting-item">
                        <label>Export Data</label>
                        <div class="export-buttons">
                            <button class="memory-btn" id="exportConversationsBtn">
                                <i class="fas fa-download"></i>
                                Export Conversations
                            </button>
                            <button class="memory-btn" id="exportSettingsBtn">
                                <i class="fas fa-cog"></i>
                                Export Settings
                            </button>
                            <button class="memory-btn" id="exportAllDataBtn">
                                <i class="fas fa-file-archive"></i>
                                Export All Data
                            </button>
                        </div>
                        <small>Download your conversations and settings as JSON files</small>
                    </div>
                    <div class="setting-item">
                        <label>Import Data</label>
                        <div class="import-container">
                            <input type="file" id="importDataInput" accept=".json" style="display: none;">
                            <button class="memory-btn secondary" id="importDataBtn">
                                <i class="fas fa-upload"></i>
                                Import Data
                            </button>
                        </div>
                        <small>Import previously exported conversations and settings</small>
                    </div>
                </div>

                <div class="settings-section">
                    <h3>Memory Management</h3>
                    <div class="memory-info" id="memoryInfo">
                        <div class="memory-stat">
                            <span class="memory-label">Stored Conversations:</span>
                            <span class="memory-value" id="conversationCount">0</span>
                        </div>
                        <div class="memory-stat">
                            <span class="memory-label">Remembered Topics:</span>
                            <span class="memory-value" id="topicCount">0</span>
                        </div>
                        <div class="memory-stat">
                            <span class="memory-label">Personal Info Items:</span>
                            <span class="memory-value" id="personalInfoCount">0</span>
                        </div>
                    </div>
                    <div class="memory-actions">
                        <button class="memory-btn" id="viewMemoryBtn">View My Memory</button>
                        <button class="memory-btn danger" id="clearMemoryBtn">Clear Memory</button>
                    </div>
                </div>

                <div class="settings-actions">
                    <button class="settings-btn secondary" id="resetSettingsBtn">Reset to Defaults</button>
                    <button class="settings-btn primary" id="saveSettingsBtn">Save Settings</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Memory Viewer Modal -->
    <div class="modal-overlay" id="memoryModalOverlay">
        <div class="auth-modal" id="memoryModal" style="max-width: 700px;">
            <div class="modal-header">
                <h2>My Memory</h2>
                <p>What I remember about you</p>
                <button class="modal-close" id="closeMemoryModal">&times;</button>
            </div>
            <div class="memory-viewer-content" id="memoryViewerContent">
                <!-- Memory content will be populated here -->
            </div>
        </div>
    </div>

    <!-- Share Modal -->
    <div class="modal-overlay" id="shareModalOverlay">
        <div class="auth-modal" id="shareModal" style="max-width: 500px;">
            <div class="modal-header">
                <h2>Share Talkie Gen AI</h2>
                <p>Share this amazing AI assistant with others</p>
                <button class="modal-close" id="closeShareModal">&times;</button>
            </div>
            <div class="share-content">
                <div class="share-section">
                    <h3>Share on Social Media</h3>
                    <div class="share-platforms">
                        <button class="share-platform-btn twitter" id="shareTwitter">
                            <i class="fab fa-twitter"></i>
                            <span>Twitter</span>
                        </button>
                        <button class="share-platform-btn facebook" id="shareFacebook">
                            <i class="fab fa-facebook"></i>
                            <span>Facebook</span>
                        </button>
                        <button class="share-platform-btn linkedin" id="shareLinkedIn">
                            <i class="fab fa-linkedin"></i>
                            <span>LinkedIn</span>
                        </button>
                        <button class="share-platform-btn reddit" id="shareReddit">
                            <i class="fab fa-reddit"></i>
                            <span>Reddit</span>
                        </button>
                        <button class="share-platform-btn whatsapp" id="shareWhatsApp">
                            <i class="fab fa-whatsapp"></i>
                            <span>WhatsApp</span>
                        </button>
                        <button class="share-platform-btn telegram" id="shareTelegram">
                            <i class="fab fa-telegram"></i>
                            <span>Telegram</span>
                        </button>
                    </div>
                </div>
                
                <div class="share-section">
                    <h3>Copy Link</h3>
                    <div class="copy-link-container">
                        <input type="text" id="shareUrlInput" readonly value="https://talkiegen.me" />
                        <button class="copy-link-btn" id="copyShareLink">
                            <i class="fas fa-copy"></i>
                            <span>Copy</span>
                        </button>
                    </div>
                </div>
                
                <div class="share-section">
                    <h3>Direct Actions</h3>
                    <div class="share-actions">
                        <button class="share-action-btn" id="shareEmail">
                            <i class="fas fa-envelope"></i>
                            <span>Share via Email</span>
                        </button>
                        <button class="share-action-btn" id="shareSMS">
                            <i class="fas fa-sms"></i>
                            <span>Share via SMS</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Documentation Modal -->
    <div class="modal-overlay" id="docsModalOverlay">
        <div class="auth-modal" id="docsModal" style="max-width: 800px; max-height: 90vh;">
            <div class="modal-header">
                <h2>Talkie Gen AI Documentation</h2>
                <p>Everything you need to know about features and capabilities</p>
                <button class="modal-close" id="closeDocsModal">&times;</button>
            </div>
            <div class="docs-content" id="docsContent">
                <!-- Documentation content will be populated here -->
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>